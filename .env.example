# ------------------------------------------------------------------
# PROJECT SETTINGS
# ------------------------------------------------------------------
COMPOSE_PROJECT_NAME=luanti-learning-universe
DOMAIN_NAME=localhost

# ------------------------------------------------------------------
# POSTGRESQL (Database)
# ------------------------------------------------------------------
POSTGRES_USER=directus
# Generiere mit: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-generated-secure-password
POSTGRES_DB=directus
POSTGRES_VERSION=15

# ------------------------------------------------------------------
# DIRECTUS (Headless CMS / LMS Backend)
# ------------------------------------------------------------------
# Sicherheitsschlüssel für JWT & Encryption
# Generiere mit: openssl rand -hex 32
KEY=replace-with-generated-64-char-hex
# Generiere mit: openssl rand -hex 32
SECRET=replace-with-generated-64-char-hex

# Initialer Admin User
ADMIN_EMAIL=admin@your-domain.com
# Mindestens 16 Zeichen mit Sonderzeichen
ADMIN_PASSWORD=replace-with-strong-admin-password

# URLs
PUBLIC_URL=https://api.your-domain.com
CORS_ORIGIN=https://frontend.your-domain.com

# Admin Static Token
# Generiere in Directus: Settings -> Access Tokens -> Create Token
DIRECTUS_ADMIN_TOKEN=replace-with-generated-admin-token

# Caching (Redis)
CACHE_ENABLED=true
CACHE_STORE=redis
CACHE_REDIS=redis://cache:6379

# ------------------------------------------------------------------
# LUANTI (Game Server)
# ------------------------------------------------------------------
LUANTI_PORT=30000

# ------------------------------------------------------------------
# TRAEFIK (Reverse Proxy)
# ------------------------------------------------------------------
# Dashboard User (Basic Auth): admin / changeme (Generiert mit htpasswd)
# Aktueller Hash für "changeme": $apr1$H6uskkkW$IgXLP6ewn3SnUL3ki1aE70
TRAEFIK_DASHBOARD_AUTH=admin:$apr1$H6uskkkW$IgXLP6ewn3SnUL3ki1aE70