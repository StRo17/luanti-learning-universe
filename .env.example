# ------------------------------------------------------------------
# PROJECT SETTINGS
# ------------------------------------------------------------------
COMPOSE_PROJECT_NAME=luanti-learning-universe
DOMAIN_NAME=localhost

# ------------------------------------------------------------------
# POSTGRESQL (Database)
# ------------------------------------------------------------------
POSTGRES_USER=directus
POSTGRES_PASSWORD=secure_db_password_change_me
POSTGRES_DB=directus
POSTGRES_VERSION=15

# ------------------------------------------------------------------
# DIRECTUS (Headless CMS / LMS Backend)
# ------------------------------------------------------------------
# Sicherheitsschlüssel für JWT & Encryption (Generiere neue UUIDs für Prod!)
KEY=replace-with-random-uuid-v4
SECRET=replace-with-random-uuid-v4

# Initialer Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin-password-change-me

# URLs
PUBLIC_URL=http://localhost:8055

# Caching (Redis)
CACHE_ENABLED=true
CACHE_STORE=redis
CACHE_REDIS=redis://cache:6379

# ------------------------------------------------------------------
# LUANTI (Game Server)
# ------------------------------------------------------------------
LUANTI_PORT=30000

# ------------------------------------------------------------------
# TRAEFIK (Reverse Proxy)
# ------------------------------------------------------------------
# Dashboard User (Basic Auth): admin / changeme (Generiert mit htpasswd)
# Aktueller Hash für "changeme": $apr1$H6uskkkW$IgXLP6ewn3SnUL3ki1aE70
TRAEFIK_DASHBOARD_AUTH=admin:$apr1$H6uskkkW$IgXLP6ewn3SnUL3ki1aE70