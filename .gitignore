# ==================================================================
# Luanti Learning Universe - .gitignore
# ==================================================================

# ------------------------------------------------------------------
# Environment & Secrets
# ------------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------------
# Directus / Backend
# ------------------------------------------------------------------
# User Uploads (können groß werden, nicht ins Repo!)
backend/uploads/*
!backend/uploads/.gitkeep

# Timestamped Schema Backups (nur snapshot.yaml wird committed)
backend/schema/snapshot_*.yaml
!backend/schema/snapshot.yaml
!backend/schema/.gitkeep

# Extension Build Artifacts
backend/extensions/**/dist/
backend/extensions/**/node_modules/

# ------------------------------------------------------------------
# Luanti / Game Server
# ------------------------------------------------------------------
# World-Daten (werden in Docker Volume gespeichert)
luanti/worlds/*
!luanti/worlds/.gitkeep

# Debug Logs
luanti/*.log
luanti/debug.txt

# Build Artifacts
luanti/**/*.so
luanti/**/*.dll

# ------------------------------------------------------------------
# Traefik / Proxy
# ------------------------------------------------------------------
# SSL Zertifikate (sensibel!)
proxy/acme.json

# ------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------
# Docker Volumes werden nicht commited
docker-compose.override.yml

# ------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------
logs/
*.log

# ------------------------------------------------------------------
# Development
# ------------------------------------------------------------------
# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Backup Files
*.bak
*.backup
*.old

# Temporary Files
tmp/
temp/
*.tmp

# ------------------------------------------------------------------
# Node.js (falls Extensions TypeScript nutzen)
# ------------------------------------------------------------------
node_modules/
npm-debug.log
yarn-error.log
.pnpm-debug.log

# ------------------------------------------------------------------
# Python (falls Backend-Scripts genutzt werden)
# ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
venv/
.env

# ------------------------------------------------------------------
# Database Dumps (außer Schema-Snapshots)
# ------------------------------------------------------------------
*.sql
*.dump
!schema.sql

# ==================================================================
# WICHTIG: Folgende Dateien MÜSSEN ins Repo:
# - docker-compose.yml
# - .env.example
# - backend/extensions/ (Code)
# - luanti/mods/ (Code)
# - luanti/minetest.conf
# - proxy/traefik.yml
# ==================================================================